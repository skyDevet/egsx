{
  "name": "egsx",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 3000 --base=/egsx/",
    "build": "vite build --base=/egsx/",
    "preview": "vite preview --host --base=/egsx/",
    "build:github": "vite build --base=/egsx/",
      "deploy": "npm run build:github && npx gh-pages -d dist -b gh-pages -r https://github.com/skyDevet/egsx.git --force",
  },
  "dependencies": {
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.0",
    "gh-pages": "^6.3.0",
    "vite": "^5.0.0"
  }
}
