{
  "name": "hello",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 3000 --base=/egsz",
    "build": "vite build --base=/egsz",
    "preview": "vite preview --host --base=/egsz",
    "build:github": "vite build --base=/",
    "deploy": "npm run build:github && npx gh-pages -d dist -b gh-pages -r https://github.com/skyDevet/egsz.git",
    "capacitor:add": "npx cap add android",
    "capacitor:sync": "npx cap sync",
    "capacitor:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "compromise": "^14.14.4",
    "highlight.js": "^11.11.1",
    "idb": "^8.0.3",
    "marked": "^18.0.5",
    "onnxruntime-web": "^1.26.0",
    "pdfjs-dist": "^5.7.284",
    "preact": "^10.22.0",
    "preact-router": "^4.1.2",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.0",
    "gh-pages": "^6.3.0",
    "vite": "^5.0.0"
  }
}